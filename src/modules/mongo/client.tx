// Mongo wire-protocol client. This module owns message framing, authentication, and command execution.
import std:net;
import std:binary;
import { buildScramContinue, buildScramStart, binaryPayloadToText, generateScramNonce, validateScramFinal } from "./auth.tx";
import { decodeDocumentFromReader, encodeDocument, encodeDocumentWithKeys, bsonBinary } from "./bson.tx";
import { MongoConnectionConfig } from "./config.tx";
import { MongoJsonObject, objectOf } from "./json.tx";

function mongoOpMsg(): int {
    return 2013;
}

function mongoSectionBody(): int {
    return 0;
}

function mongoSectionSequence(): int {
    return 1;
}

let mongoRuntimePrimed: int64 = 0;

function okValue(result: MongoJsonObject): bool {
    if (!result.has("ok")) {
        return true;
    }

    let kind: string = result.kind("ok");
    if (kind == "bool") {
        return result.bool("ok");
    }

    if (kind == "int" || kind == "int32" || kind == "int64") {
        return result.int64("ok") != 0;
    }

    return result.float("ok") >= 1.0;
}

function commandError(result: MongoJsonObject): string {
    if (result.has("errmsg")) {
        return result.string("errmsg");
    }
    if (result.has("codeName")) {
        return result.string("codeName");
    }
    return "Unknown MongoDB command error";
}

function withDatabase(command: MongoJsonObject, database: string): MongoJsonObject {
    let enriched: MongoJsonObject = objectOf({});
    let orderedKeys: string[] = [];
    // Preserve BSON field order because some Mongo commands are easier to debug and compare when stable.
    let keys: string[] = command.has("_bsonOrder") ? command.stringArray("_bsonOrder") : command.keys();
    for (let i: int = 0; i < keys.length(); i++) {
        let key: string = keys[i];
        if (key == "_bsonOrder") {
            continue;
        }
        command.copyField(enriched, key, key);
        orderedKeys.push(key);
    }
    enriched.setString("$db", database);
    orderedKeys.push("$db");
    enriched.setStringArray("_bsonOrder", orderedKeys);
    return enriched;
}

function withDocumentId(document: MongoJsonObject): MongoJsonObject {
    let cloned: MongoJsonObject = objectOf({});
    let keys: string[] = document.keys();
    for (let i: int = 0; i < keys.length(); i++) {
        let key: string = keys[i];
        document.copyField(cloned, key, key);
    }

    if (!cloned.has("_id") && document.has("id")) {
        document.copyField(cloned, "id", "_id");
    }

    return cloned;
}

function stableText(text: string): string {
    return binary.toString(binary.fromString(text));
}

function orderedIntCommand(commandName: string, commandValue: int, extraFields: Optional<MongoJsonObject> = None, extraOrder: string[] = []): MongoJsonObject {
    let command: MongoJsonObject = objectOf({});
    let order: string[] = [commandName];
    command.setInt(commandName, commandValue);

    if (extraFields != None) {
        let extra: MongoJsonObject = extraFields as MongoJsonObject;
        for (let i: int = 0; i < extraOrder.length(); i++) {
            let key: string = extraOrder[i];
            if (key == "_bsonOrder") {
                continue;
            }
            extra.copyField(command, key, key);
            order.push(key);
        }
    }

    command.setStringArray("_bsonOrder", order);
    return command;
}

function orderedStringCommand(commandName: string, commandValue: string, extraFields: Optional<MongoJsonObject> = None, extraOrder: string[] = []): MongoJsonObject {
    let command: MongoJsonObject = objectOf({});
    let order: string[] = [commandName];
    command.setString(commandName, commandValue);

    if (extraFields != None) {
        let extra: MongoJsonObject = extraFields as MongoJsonObject;
        for (let i: int = 0; i < extraOrder.length(); i++) {
            let key: string = extraOrder[i];
            if (key == "_bsonOrder") {
                continue;
            }
            extra.copyField(command, key, key);
            order.push(key);
        }
    }

    command.setStringArray("_bsonOrder", order);
    return command;
}

function readRawMessage(stream: TcpStream): MongoJsonObject {
    let headerBytes: Optional<int[]> = stream.readExactBytes(16);
    if (headerBytes == None) {
        throw new Error("MongoDB did not return a message header");
    }

    let headerReader: ByteReader = binary.reader(headerBytes as int[]);
    let messageLength: int = headerReader.readI32LE();
    headerReader.readI32LE();
    headerReader.readI32LE();
    let opCode: int = headerReader.readI32LE();
    if (opCode != mongoOpMsg()) {
        throw new Error("Unexpected MongoDB opcode " + String(opCode));
    }

    let payloadBytes: Optional<int[]> = stream.readExactBytes(messageLength - 16);
    if (payloadBytes == None) {
        throw new Error("MongoDB response payload was truncated");
    }

    // OP_MSG responses begin with flags and then one or more sections. This client expects a body section.
    let payloadReader: ByteReader = binary.reader(payloadBytes as int[]);
    payloadReader.readI32LE();
    let sectionKind: int = payloadReader.readU8();
    if (sectionKind != mongoSectionBody()) {
        throw new Error("Unsupported MongoDB section kind " + String(sectionKind));
    }

    return decodeDocumentFromReader(payloadReader);
}

function sendRawCommand(host: string, port: int, requestId: int, command: MongoJsonObject): void {
    let maybeStream: Optional<TcpStream> = net.connectHost(host, port);
    if (maybeStream == None) {
        throw new Error("Failed to connect to MongoDB at " + host + ":" + String(port));
    }
    let stream: TcpStream = maybeStream as TcpStream;

    let bodyDocument: int[] = binary.concat([encodeDocument(command)]);
    let payloadWriter: ByteWriter = binary.writer();
    payloadWriter.writeI32LE(0);
    payloadWriter.writeU8(mongoSectionBody());
    payloadWriter.writeBytes(bodyDocument);
    let payload: int[] = payloadWriter.toBytes();

    let headerWriter: ByteWriter = binary.writer();
    headerWriter.writeI32LE(payload.length() + 16);
    headerWriter.writeI32LE(requestId);
    headerWriter.writeI32LE(0);
    headerWriter.writeI32LE(mongoOpMsg());
    let packet: int[] = binary.concat([headerWriter.toBytes(), payload]);

    if (!stream.writeBytes(packet)) {
        safeClose(stream);
        throw new Error("Failed to write MongoDB command to " + host + ":" + String(port));
    }

    readRawMessage(stream);
    safeClose(stream);
}

export function primeMongoConnection(connection: MongoConnectionConfig): void {
    let host: string = stableText(connection.host);
    let port: int = connection.port;
    let database: string = stableText(connection.database);

    let pingFields: MongoJsonObject = objectOf({});
    pingFields.setString("$db", database);
    sendRawCommand(host, port, 1, orderedIntCommand("ping", 1, pingFields, ["$db"]));

    // Warm up the runtime with one lightweight read so later state loads are less surprising.
    try {
        let filter: MongoJsonObject = objectOf({});
        filter.setString("_id", "app-meta");
        let findFields: MongoJsonObject = objectOf({});
        findFields.setObject("filter", filter);
        findFields.setInt("limit", 1);
        findFields.setBool("singleBatch", true);
        findFields.setString("$db", database);
        sendRawCommand(host, port, 2, orderedStringCommand("find", "app_meta", findFields, ["filter", "limit", "singleBatch", "$db"]));
    } catch (primeError) {
    }
}

function safeClose(stream: TcpStream): void {
    try {
        stream.close();
    } catch (closeError) {
    }
}

export class MongoClient {
    private host: string;
    private port: int;
    private databaseNameValue: string;
    private username: string;
    private password: string;
    private authDatabaseName: string;
    private requestId: int;
    private streamState: Optional<TcpStream>;
    private streamOpen: bool;

    constructor(connection: MongoConnectionConfig) {
        this.host = stableText(connection.host);
        this.port = connection.port;
        this.databaseNameValue = stableText(connection.database);
        this.username = connection.username != "" ? stableText(connection.username) : "";
        this.password = connection.password != "" ? stableText(connection.password) : "";
        this.authDatabaseName = connection.authDatabase != "" ? stableText(connection.authDatabase) : "";
        if (this.authDatabaseName == "" && this.username != "") {
            this.authDatabaseName = this.databaseNameValue != "" ? stableText(this.databaseNameValue) : "admin";
        }
        this.requestId = 1;
        this.streamState = None;
        this.streamOpen = false;
    }

    databaseName(): string {
        return stableText(this.databaseNameValue);
    }

    address(): string {
        return this.host + ":" + String(this.port);
    }

    private needsAuthentication(): bool {
        return this.username != "";
    }

    private nextRequestId(): int {
        let current: int = this.requestId;
        this.requestId = this.requestId + 1;
        return current;
    }

    private connect(): TcpStream {
        let maybeStream: Optional<TcpStream> = net.connectHost(this.host, this.port);
        if (maybeStream == None) {
            throw new Error("Failed to connect to MongoDB at " + this.address());
        }
        return maybeStream as TcpStream;
    }

    // Reuse one authenticated socket per client instance to keep request latency down.
    private openStream(): TcpStream {
        if (this.streamOpen) {
            return this.streamState as TcpStream;
        }

        this.requestId = 1;
        let stream: TcpStream = this.connect();
        this.authenticateStream(stream);
        this.streamState = stream;
        this.streamOpen = true;
        return stream;
    }

    private primeRuntime(): void {
        if (mongoRuntimePrimed != 0) {
            return;
        }

        primeMongoConnection(new MongoConnectionConfig(
            "",
            this.host,
            this.port,
            this.databaseNameValue,
            "",
            "",
            "",
            ""
        ));
        mongoRuntimePrimed = 1;
    }

    private readMessage(stream: TcpStream): MongoJsonObject {
        let headerBytes: Optional<int[]> = stream.readExactBytes(16);
        if (headerBytes == None) {
            throw new Error("MongoDB did not return a message header");
        }

        let headerReader: ByteReader = binary.reader(headerBytes as int[]);
        let messageLength: int = headerReader.readI32LE();
        let responseId: int = headerReader.readI32LE();
        let responseTo: int = headerReader.readI32LE();
        let opCode: int = headerReader.readI32LE();

        if (opCode != mongoOpMsg()) {
            throw new Error("Unexpected MongoDB opcode " + String(opCode));
        }

        let remainingLength: int = messageLength - 16;
        let payloadBytes: Optional<int[]> = stream.readExactBytes(remainingLength);
        if (payloadBytes == None) {
            throw new Error("MongoDB response payload was truncated");
        }

        let payloadReader: ByteReader = binary.reader(payloadBytes as int[]);
        let flagBits: int = payloadReader.readI32LE();
        let sectionKind: int = payloadReader.readU8();
        if (sectionKind != mongoSectionBody()) {
            throw new Error("Unsupported MongoDB section kind " + String(sectionKind));
        }

        let document: MongoJsonObject = decodeDocumentFromReader(payloadReader);
        document.setInt("_responseId", responseId);
        document.setInt("_responseTo", responseTo);
        document.setInt("_flags", flagBits);
        return document;
    }

    private sendCommandOnStream(stream: TcpStream, command: MongoJsonObject, database: string): MongoJsonObject {
        let commandBody: MongoJsonObject = withDatabase(command, database);
        return this.sendPayloadOnStream(stream, commandBody, None, None);
    }

    // Send either a plain command body or a command plus sequence payload documents.
    private sendPayloadOnStream(
        stream: TcpStream,
        commandBody: MongoJsonObject,
        sequenceName: Optional<string>,
        sequenceDocuments: Optional<MongoJsonObject[]>
    ): MongoJsonObject {
        let requestId: int = this.nextRequestId();
        let bodyDocument: int[] = commandBody.has("_bsonOrder")
            ? encodeDocumentWithKeys(commandBody, commandBody.stringArray("_bsonOrder"))
            : encodeDocument(commandBody);
        let stableBodyDocument: int[] = binary.concat([bodyDocument]);

        let payloadWriter: ByteWriter = binary.writer();
        payloadWriter.writeI32LE(0);
        payloadWriter.writeU8(mongoSectionBody());
        payloadWriter.writeBytes(stableBodyDocument);

        if (sequenceName != None && sequenceDocuments != None) {
            // Bulk write commands encode extra documents in a second OP_MSG section.
            let docs: MongoJsonObject[] = sequenceDocuments as MongoJsonObject[];
            let sequenceWriter: ByteWriter = binary.writer();
            sequenceWriter.writeCString(sequenceName as string);
            for (let i: int = 0; i < docs.length(); i++) {
                sequenceWriter.writeBytes(binary.concat([encodeDocument(docs[i])]));
            }

            let sequenceBytes: int[] = sequenceWriter.toBytes();
            payloadWriter.writeU8(mongoSectionSequence());
            payloadWriter.writeI32LE(sequenceBytes.length() + 4);
            payloadWriter.writeBytes(sequenceBytes);
        }

        let payload: int[] = payloadWriter.toBytes();

        let headerWriter: ByteWriter = binary.writer();
        headerWriter.writeI32LE(payload.length() + 16);
        headerWriter.writeI32LE(requestId);
        headerWriter.writeI32LE(0);
        headerWriter.writeI32LE(mongoOpMsg());
        let packet: int[] = binary.concat([headerWriter.toBytes(), payload]);

        if (!stream.writeBytes(packet)) {
            throw new Error("Failed to write MongoDB command to " + this.address());
        }

        let response: MongoJsonObject = this.readMessage(stream);
        if (!okValue(response)) {
            throw new Error(commandError(response));
        }

        return response;
    }

    // Run the SCRAM handshake only when credentials are configured.
    private authenticateStream(stream: TcpStream): void {
        if (!this.needsAuthentication()) {
            return;
        }

        let databaseName: string = stableText(this.databaseNameValue);
        let username: string = stableText(this.username);
        let password: string = stableText(this.password);
        let authDatabase: string = this.authDatabaseName != "" ? stableText(this.authDatabaseName) : "admin";

        if (password == "") {
            throw new Error("MongoDB password is required when a username is configured");
        }
        let nonce: string = generateScramNonce(username + ":" + this.address() + ":" + String(this.requestId));
        let start: MongoJsonObject = buildScramStart(username, nonce);
        let startOptions: MongoJsonObject = objectOf({});
        startOptions.setBool("skipEmptyExchange", true);
        let startFields: MongoJsonObject = objectOf({});
        startFields.setString("mechanism", "SCRAM-SHA-256");
        startFields.setObject("payload", bsonBinary(binary.fromString(start.string("message"))));
        startFields.setInt("autoAuthorize", 1);
        startFields.setObject("options", startOptions);
        let startResponse: MongoJsonObject = this.sendCommandOnStream(stream, orderedIntCommand("saslStart", 1, startFields, ["mechanism", "payload", "autoAuthorize", "options"]), authDatabase);

        let conversationId: int = startResponse.int("conversationId");
        let startPayloadValue: Optional<MongoJsonObject> = startResponse.object("payload");
        let serverFirstMessage: string = binaryPayloadToText(startPayloadValue as MongoJsonObject);
        let next: MongoJsonObject = buildScramContinue(
            username,
            password,
            start.string("clientFirstBare"),
            serverFirstMessage
        );

        let continueFields: MongoJsonObject = objectOf({});
        continueFields.setInt("conversationId", conversationId);
        continueFields.setObject("payload", bsonBinary(binary.fromString(next.string("message"))));
        let continueResponse: MongoJsonObject = this.sendCommandOnStream(stream, orderedIntCommand("saslContinue", 1, continueFields, ["conversationId", "payload"]), authDatabase);

        let continuePayloadValue: Optional<MongoJsonObject> = continueResponse.object("payload");
        validateScramFinal(binaryPayloadToText(continuePayloadValue as MongoJsonObject), next.string("serverSignature"));
        if (!continueResponse.boolOr("done", false)) {
            let finalFields: MongoJsonObject = objectOf({});
            finalFields.setInt("conversationId", conversationId);
            finalFields.setObject("payload", bsonBinary([]));
            let finalResponse: MongoJsonObject = this.sendCommandOnStream(stream, orderedIntCommand("saslContinue", 1, finalFields, ["conversationId", "payload"]), authDatabase);

            let finalPayloadValue: Optional<MongoJsonObject> = finalResponse.object("payload");
            let finalMessage: string = binaryPayloadToText(finalPayloadValue as MongoJsonObject);
            if (finalMessage != "") {
                validateScramFinal(finalMessage, next.string("serverSignature"));
            }

            if (!finalResponse.boolOr("done", false)) {
                throw new Error("MongoDB authentication conversation did not complete");
            }
        }

        // The SCRAM path stresses the runtime heavily; restore the stable field copies
        // so later commands keep their configured database/auth values.
        this.databaseNameValue = databaseName;
        this.username = username;
        this.password = password;
        this.authDatabaseName = authDatabase;
    }

    private runCommand(command: MongoJsonObject, database: string): MongoJsonObject {
        try {
            let streamValue: TcpStream = this.openStream();
            let response: MongoJsonObject = this.sendCommandOnStream(streamValue, command, database);
            return response;
        } catch (error) {
            if (this.streamOpen) {
                safeClose(this.streamState as TcpStream);
                this.streamState = None;
                this.streamOpen = false;
            }
            throw error;
        }
    }

    private runCommandWithSequence(command: MongoJsonObject, database: string, sequenceName: string, sequenceDocuments: MongoJsonObject[]): MongoJsonObject {
        let commandBody: MongoJsonObject = withDatabase(command, database);

        try {
            let streamValue: TcpStream = this.openStream();
            let response: MongoJsonObject = this.sendPayloadOnStream(streamValue, commandBody, sequenceName, sequenceDocuments);
            return response;
        } catch (error) {
            if (this.streamOpen) {
                safeClose(this.streamState as TcpStream);
                this.streamState = None;
                this.streamOpen = false;
            }
            throw error;
        }
    }

    command(command: MongoJsonObject): MongoJsonObject {
        return this.runCommand(command, stableText(this.databaseNameValue));
    }

    commandOnDatabase(command: MongoJsonObject, database: string): MongoJsonObject {
        return this.runCommand(command, stableText(database));
    }

    ping(): void {
        this.command(orderedIntCommand("ping", 1));
    }

    find(collection: string, filter: MongoJsonObject): MongoJsonObject[] {
        let findFields: MongoJsonObject = objectOf({});
        findFields.setObject("filter", filter);
        let response: MongoJsonObject = this.runCommand(orderedStringCommand("find", collection, findFields, ["filter"]), stableText(this.databaseNameValue));

        let cursorValue: Optional<MongoJsonObject> = response.object("cursor");
        if (cursorValue == None) {
            return [];
        }

        let cursor: MongoJsonObject = cursorValue as MongoJsonObject;
        return cursor.objectArray("firstBatch");
    }

    findOne(collection: string, filter: MongoJsonObject): Optional<MongoJsonObject> {
        let commandParams: MongoJsonObject = objectOf({});
        commandParams.setObject("filter", filter);
        commandParams.setInt("limit", 1);
        commandParams.setBool("singleBatch", true);
        let command: MongoJsonObject = orderedStringCommand("find", collection, commandParams, ["filter", "limit", "singleBatch"]);
        let dbName: string = stableText(this.databaseNameValue);
        let response: MongoJsonObject = this.runCommand(command, dbName);

        let cursorValue: Optional<MongoJsonObject> = response.object("cursor");
        if (cursorValue == None) {
            return None;
        }

        let docs: MongoJsonObject[] = (cursorValue as MongoJsonObject).objectArray("firstBatch");
        if (docs.length() == 0) {
            return None;
        }

        return docs[0];
    }

    insertOne(collection: string, document: MongoJsonObject): MongoJsonObject {
        let commandFields: MongoJsonObject = objectOf({});
        commandFields.setObjectArray("documents", [withDocumentId(document)]);
        return this.runCommand(
            orderedStringCommand("insert", collection, commandFields, ["documents"]),
            stableText(this.databaseNameValue)
        );
    }

    updateOne(collection: string, filter: MongoJsonObject, setFields: MongoJsonObject): MongoJsonObject {
        let setDocument: MongoJsonObject = objectOf({});
        setDocument.setObject("$set", setFields);
        let updateDocument: MongoJsonObject = objectOf({});
        updateDocument.setObject("q", filter);
        updateDocument.setObject("u", setDocument);
        updateDocument.setBool("upsert", false);
        let commandFields: MongoJsonObject = objectOf({});
        commandFields.setObjectArray("updates", [updateDocument]);
        return this.runCommand(
            orderedStringCommand("update", collection, commandFields, ["updates"]),
            stableText(this.databaseNameValue)
        );
    }

    upsertOne(collection: string, filter: MongoJsonObject, setFields: MongoJsonObject): MongoJsonObject {
        let setDocument: MongoJsonObject = objectOf({});
        setDocument.setObject("$set", setFields);
        let updateDocument: MongoJsonObject = objectOf({});
        updateDocument.setObject("q", filter);
        updateDocument.setObject("u", setDocument);
        updateDocument.setBool("upsert", true);
        let commandFields: MongoJsonObject = objectOf({});
        commandFields.setObjectArray("updates", [updateDocument]);
        return this.runCommand(
            orderedStringCommand("update", collection, commandFields, ["updates"]),
            stableText(this.databaseNameValue)
        );
    }

    deleteOne(collection: string, filter: MongoJsonObject): MongoJsonObject {
        let deleteDocument: MongoJsonObject = objectOf({});
        deleteDocument.setObject("q", filter);
        deleteDocument.setInt("limit", 1);
        let commandFields: MongoJsonObject = objectOf({});
        commandFields.setObjectArray("deletes", [deleteDocument]);
        return this.runCommand(
            orderedStringCommand("delete", collection, commandFields, ["deletes"]),
            stableText(this.databaseNameValue)
        );
    }

    close(): void {
        if (this.streamOpen) {
            safeClose(this.streamState as TcpStream);
            this.streamState = None;
            this.streamOpen = false;
        }
    }
}
