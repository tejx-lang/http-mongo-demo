// Small typed JSON helper built on top of the language's built-in std:json support.
import std:json;

function stringValue(value: any, fallback: string = ""): string {
    if (value == None) {
        return fallback;
    }
    return String(value);
}

function intValue(value: any, fallback: int = 0): int {
    if (value == None) {
        return fallback;
    }

    let kind: string = typeof(value);
    if (kind == "int" || kind == "int32" || kind == "int64") {
        return value as int;
    }
    if (kind == "float" || kind == "float32" || kind == "float64") {
        return (value as float) as int;
    }
    if (kind == "bool") {
        return (value as bool) ? 1 : 0;
    }

    return parseFloat(String(value)) as int;
}

function int64Value(value: any, fallback: int64 = 0): int64 {
    if (value == None) {
        return fallback;
    }

    let kind: string = typeof(value);
    if (kind == "int64") {
        return value as int64;
    }
    if (kind == "int" || kind == "int32") {
        return value as int64;
    }
    if (kind == "float" || kind == "float32" || kind == "float64") {
        return (value as float) as int64;
    }

    return (parseFloat(String(value)) as int) as int64;
}

function floatValue(value: any, fallback: float = 0.0): float {
    if (value == None) {
        return fallback;
    }

    let kind: string = typeof(value);
    if (kind == "float" || kind == "float32" || kind == "float64") {
        return value as float;
    }
    if (kind == "int" || kind == "int32" || kind == "int64") {
        return (value as int64) as float;
    }
    if (kind == "bool") {
        return (value as bool) ? 1.0 : 0.0;
    }

    return parseFloat(String(value));
}

function cloneJsonValue(value: any): any {
    if (value == None) {
        return None;
    }

    if (typeof(value) == "array") {
        let values: any[] = value as any[];
        let out: any[] = [];
        for (let i: int = 0; i < values.length(); i++) {
            out.push(cloneJsonValue(values[i]));
        }
        return out;
    }

    if (typeof(value) == "object") {
        let out: any = {};
        let keys: string[] = Object.keys(value);
        for (let i: int = 0; i < keys.length(); i++) {
            let key: string = keys[i];
            out[key] = cloneJsonValue(value[key]);
        }
        return out;
    }

    return value;
}

function normalizeObjectValue(value: any): any {
    if (value == None) {
        return {};
    }

    if (typeof(value["toJSON"]) == "function") {
        return value.toJSON();
    }

    return value;
}

export class JsonObject {
    private values: any;

    constructor(values: any) {
        this.values = normalizeObjectValue(values);
    }

    private read<T>(key: string): Optional<T> {
        let value: any = this.values[key];
        if (value == None) {
            return None;
        }
        return value as T;
    }

    private readRaw(key: string): Optional<any> {
        return this.read<any>(key);
    }

    private readArray(key: string): Optional<any[]> {
        return this.read<any[]>(key);
    }

    has(key: string): bool {
        return this.values[key] != None;
    }

    kind(key: string): string {
        let value: Optional<any> = this.readRaw(key);
        if (value == None) {
            return "None";
        }
        return typeof(value as any);
    }

    keys(): string[] {
        return Object.keys(this.values);
    }

    string(key: string): string {
        return stringValue(this.values[key], "");
    }

    stringOr(key: string, fallback: string): string {
        return stringValue(this.values[key], fallback);
    }

    int(key: string): int {
        return intValue(this.values[key], 0);
    }

    intOr(key: string, fallback: int): int {
        return intValue(this.values[key], fallback);
    }

    int64(key: string): int64 {
        return int64Value(this.values[key], 0);
    }

    int64Or(key: string, fallback: int64): int64 {
        return int64Value(this.values[key], fallback);
    }

    float(key: string): float {
        return floatValue(this.values[key], 0.0);
    }

    floatOr(key: string, fallback: float): float {
        return floatValue(this.values[key], fallback);
    }

    bool(key: string): bool {
        return this.boolOr(key, false);
    }

    boolOr(key: string, fallback: bool): bool {
        let value: Optional<any> = this.readRaw(key);
        if (value == None) {
            return fallback;
        }

        let runtimeValue: any = value as any;
        let kind: string = typeof(runtimeValue);
        if (kind == "bool") {
            return runtimeValue as bool;
        }
        if (kind == "int" || kind == "int32" || kind == "int64") {
            return (runtimeValue as int64) != 0;
        }
        if (kind == "float" || kind == "float32" || kind == "float64") {
            return (runtimeValue as float) != 0.0;
        }
        if (kind == "string") {
            return (runtimeValue as string) != "";
        }

        return fallback;
    }

    object(key: string): Optional<JsonObject> {
        let normalized: any = normalizeObjectValue(this.values[key]);
        if (normalized == None || typeof(normalized) != "object") {
            return None;
        }
        return new JsonObject(normalized);
    }

    objectArray(key: string): JsonObject[] {
        let field: Optional<any[]> = this.readArray(key);
        if (field == None) {
            return [];
        }

        let out: JsonObject[] = [];
        let values: any[] = field as any[];
        for (let i: int = 0; i < values.length(); i++) {
            out.push(new JsonObject(normalizeObjectValue(values[i])));
        }
        return out;
    }

    stringArray(key: string): string[] {
        let field: Optional<any[]> = this.readArray(key);
        if (field == None) {
            return [];
        }

        let out: string[] = [];
        let values: any[] = field as any[];
        for (let i: int = 0; i < values.length(); i++) {
            out.push(stringValue(values[i]));
        }
        return out;
    }

    intArray(key: string): int[] {
        let field: Optional<any[]> = this.readArray(key);
        if (field == None) {
            return [];
        }

        let out: int[] = [];
        let values: any[] = field as any[];
        for (let i: int = 0; i < values.length(); i++) {
            out.push(intValue(values[i], 0));
        }
        return out;
    }

    copyField(target: JsonObject, sourceKey: string, targetKey: string): void {
        if (!this.has(sourceKey)) {
            return;
        }
        target.values[targetKey] = this.values[sourceKey];
    }

    setString(key: string, value: string): void {
        this.values[key] = value;
    }

    setInt(key: string, value: int): void {
        this.values[key] = value;
    }

    setInt64(key: string, value: int64): void {
        this.values[key] = value;
    }

    setFloat(key: string, value: float): void {
        this.values[key] = value;
    }

    setBool(key: string, value: bool): void {
        this.values[key] = value;
    }

    setStringArray(key: string, values: string[]): void {
        this.values[key] = values;
    }

    setIntArray(key: string, values: int[]): void {
        this.values[key] = values;
    }

    setObject(key: string, value: JsonObject): void {
        this.values[key] = value.toJSON();
    }

    setObjectArray(key: string, values: JsonObject[]): void {
        let out: any[] = [];
        for (let i: int = 0; i < values.length(); i++) {
            out.push(values[i].toJSON());
        }
        this.values[key] = out;
    }

    remove(key: string): void {
        let nextValues: any = {};
        let keys: string[] = Object.keys(this.values);
        for (let i: int = 0; i < keys.length(); i++) {
            let currentKey: string = keys[i];
            if (currentKey == key) {
                continue;
            }
            nextValues[currentKey] = this.values[currentKey];
        }
        this.values = nextValues;
    }

    toJSON(): any {
        return this.values;
    }
}

export function parse(text: string): JsonObject {
    return new JsonObject(cloneJsonValue(json.parse(text)));
}

export function parseObject(text: string): JsonObject {
    return parse(text);
}

export function parseValue(text: string): any {
    return json.parse(text);
}

export function objectOf(value: any): JsonObject {
    return new JsonObject(normalizeObjectValue(value));
}

export function plainJson(value: JsonObject): any {
    return value.toJSON();
}

export function jsonObject(value: any = {}): JsonObject {
    return objectOf(value);
}

export function emptyObject(): JsonObject {
    return objectOf({});
}

export function hasField(value: any, key: string): bool {
    if (value == None) {
        return false;
    }
    return value[key] != None;
}

export function stringField(value: any, key: string): string {
    if (value == None) {
        return "";
    }
    return stringValue(value[key], "");
}

export function stringFieldOr(value: any, key: string, fallback: string): string {
    if (value == None) {
        return fallback;
    }
    return stringValue(value[key], fallback);
}

export function intFieldOr(value: any, key: string, fallback: int): int {
    if (value == None) {
        return fallback;
    }
    return intValue(value[key], fallback);
}

export function floatFieldOr(value: any, key: string, fallback: float): float {
    if (value == None) {
        return fallback;
    }
    return floatValue(value[key], fallback);
}

export function stringArrayField(value: any, key: string): string[] {
    if (value == None) {
        return [];
    }

    let raw: any = value[key];
    if (raw == None || typeof(raw) != "array") {
        return [];
    }

    let values: any[] = raw as any[];
    let out: string[] = [];
    for (let i: int = 0; i < values.length(); i++) {
        out.push(stringValue(values[i], ""));
    }
    return out;
}

export function readString(text: string, key: string): Optional<string> {
    let value: any = parseValue(text);
    if (!hasField(value, key)) {
        return None;
    }
    return stringField(value, key);
}

export function readNumber(text: string, key: string): Optional<float> {
    let value: any = parseValue(text);
    if (!hasField(value, key)) {
        return None;
    }
    return floatFieldOr(value, key, 0.0);
}

export function readBoolean(text: string, key: string): Optional<bool> {
    let value: any = parseValue(text);
    if (!hasField(value, key)) {
        return None;
    }
    let raw: any = value[key];
    if (typeof(raw) == "bool") {
        return raw as bool;
    }
    if (typeof(raw) == "int" || typeof(raw) == "int32" || typeof(raw) == "int64") {
        return (raw as int64) != 0;
    }
    if (typeof(raw) == "float" || typeof(raw) == "float32" || typeof(raw) == "float64") {
        return (raw as float) != 0.0;
    }
    if (typeof(raw) == "string") {
        return (raw as string) != "";
    }
    return None;
}

export function readStringArray(text: string, key: string): string[] {
    return stringArrayField(parseValue(text), key);
}
