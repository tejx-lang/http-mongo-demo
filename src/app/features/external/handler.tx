// External integration endpoint. It proxies one upstream HTTP call into the app's response shape.
import { fetch } from "../../../modules/http/index.tx";
import { describeError } from "../../../modules/errors/index.tx";
import { JsonObject, objectOf } from "../../../modules/json/index.tx";
import { Response, createJsonResponse } from "../../../modules/server/index.tx";

export function handleExternal(method: string): Response {
    if (method != "GET") {
        let methodError: JsonObject = objectOf({});
        methodError.setString("error", "Method not allowed");
        return createJsonResponse(methodError, 405);
    }

    try {
        let response = fetch("https://dummyjson.com/products/1");
        return createJsonResponse(response.json().toJSON(), response.status);
    } catch (error) {
        let failure: JsonObject = objectOf({});
        failure.setString("error", "External request failed");
        failure.setString("detail", describeError(error));
        return createJsonResponse(failure, 500);
    }
}
