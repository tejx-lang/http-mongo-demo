// Simple end-to-end client that exercises the public HTTP API from outside the server process.
import { stringify } from "std:json";
import { Map } from "std:collections";
import { getEnv } from "std:system";
import { nowMs } from "std:time";
import { HttpResponse, createJsonRequestHeaders, createRequest, fetch } from "../../src/modules/http/index.tx";
import { JsonObject } from "../../src/modules/json/index.tx";

function resolveBaseUrl(): string {
    let baseUrl: string = getEnv("APP_BASE_URL");
    if (baseUrl != "") {
        return baseUrl;
    }
    return "http://127.0.0.1:3000";
}

function printResponse(label: string, status: int, body: string): void {
    print(label);
    print("Status: ", status);
    print(body);
}

function main() {
    let baseUrl: string = resolveBaseUrl();
    let suffix: string = String(nowMs());
    let email: string = "demo-" + suffix;
    let password: string = "demo123";
    let jsonHeaders: Map<string, string> = createJsonRequestHeaders();

    // Create one user, two products, then an order so the full CRUD/auth/report flow is exercised.
    let health: HttpResponse = fetch(baseUrl + "/health");
    let createUser: HttpResponse = fetch(baseUrl + "/api/users", createRequest(
        "POST",
        stringify({
        name: "Demo User " + suffix,
        email: email,
        password: password,
        role: "customer"
    }),
        jsonHeaders
    ));
    let createKeyboard: HttpResponse = fetch(baseUrl + "/api/products", createRequest(
        "POST",
        stringify({
        name: "Keyboard " + suffix,
        price: 99.99,
        stock: 15,
        category: "accessories"
    }),
        jsonHeaders
    ));
    let createMouse: HttpResponse = fetch(baseUrl + "/api/products", createRequest(
        "POST",
        stringify({
        name: "Mouse " + suffix,
        price: 49.5,
        stock: 22,
        category: "accessories"
    }),
        jsonHeaders
    ));

    let userData: JsonObject = createUser.json();
    let keyboardData: JsonObject = createKeyboard.json();
    let mouseData: JsonObject = createMouse.json();

    let login: HttpResponse = fetch(baseUrl + "/api/auth/login", createRequest(
        "POST",
        stringify({
        email: email,
        password: password
    }),
        jsonHeaders
    ));
    let order: HttpResponse = fetch(baseUrl + "/api/orders", createRequest(
        "POST",
        stringify({
        userId: userData.string("id"),
        productIds: [keyboardData.string("id"), mouseData.string("id")]
    }),
        jsonHeaders
    ));
    let summary: HttpResponse = fetch(baseUrl + "/api/reports/summary");

    print("Internal API client using ", baseUrl);
    printResponse("GET /health", health.status, health.body);
    printResponse("POST /api/users", createUser.status, createUser.body);
    printResponse("POST /api/products (keyboard)", createKeyboard.status, createKeyboard.body);
    printResponse("POST /api/products (mouse)", createMouse.status, createMouse.body);
    printResponse("POST /api/auth/login", login.status, login.body);
    printResponse("POST /api/orders", order.status, order.body);
    printResponse("GET /api/reports/summary", summary.status, summary.body);
}
